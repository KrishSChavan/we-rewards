# Supabase project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server only, never ship to the browser

PORT=3000

# Operator dashboard at /admin — comma-separated emails allowed to see analytics
# + error logs. Must match the Google account you sign in with. Leave blank to
# lock everyone out of /admin.
ADMIN_EMAILS=you@example.com

# Trusted-proxy hop count for correct client IPs / rate limiting. Default 1 (one
# PaaS proxy). Set to 2 behind e.g. Cloudflare→Render, or false with no proxy.
# TRUST_PROXY=1

# Web-push keys for the admin "new vendor application" alerts. Generate once
# with: npx web-push generate-vapid-keys
# Leave blank to disable push silently (the rest of the app is unaffected).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
